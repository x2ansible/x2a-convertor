# Managed by Puppet — do not edit manually
# Profile: profile_haproxy

global
    log         <%= @log_server %> <%= @log_facility %> <%= @log_level %>
    chroot      /var/lib/haproxy
    pidfile     /var/run/haproxy.pid
    maxconn     <%= @global_maxconn %>
    user        <%= @user %>
    group       <%= @group %>
    daemon
    stats socket /var/lib/haproxy/stats mode 660 level admin
<% if @ssl_enabled -%>
    ssl-default-bind-ciphers <%= @ssl_ciphers %>
    ssl-default-bind-options no-sslv3 no-tlsv10 no-tlsv11
    tune.ssl.default-dh-param 2048
<% end -%>

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    option  forwardfor
    option  http-server-close
    timeout connect <%= @connect_timeout %>
    timeout client  <%= @client_timeout %>
    timeout server  <%= @server_timeout %>
    retries <%= @retries %>
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 408 /etc/haproxy/errors/408.http

<% if @stats_enabled -%>
listen stats
    bind *:<%= @stats_port %>
    stats enable
    stats uri <%= @stats_uri %>
    stats realm HAProxy\ Statistics
    stats auth <%= @stats_user %>:<%= @stats_password %>
    stats admin if TRUE
    stats refresh 30s
<% end -%>

frontend http_front
    bind *:80
<% if @ssl_enabled -%>
    bind *:443 ssl crt <%= @ssl_cert_path %>/haproxy.pem
    http-request redirect scheme https unless { ssl_fc }
<% end -%>
    default_backend webservers

<% @backends.each do |name, config| -%>
# Backend configuration included from conf.d/<%= name %>.cfg
<% end -%>
