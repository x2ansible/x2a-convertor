{
  "name": "example-profile_haproxy",
  "version": "2.4.1",
  "author": "Platform Team",
  "summary": "HAProxy load balancer profile with multi-backend support",
  "license": "Apache-2.0",
  "source": "https://github.com/example-org/puppet-profile_haproxy",
  "dependencies": [
    { "name": "puppetlabs-stdlib", "version_requirement": ">= 9.0.0 < 10.0.0" },
    { "name": "puppetlabs-concat", "version_requirement": ">= 9.0.0 < 10.0.0" },
