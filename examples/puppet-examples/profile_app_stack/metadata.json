{
  "name": "example-profile_app_stack",
  "version": "1.3.0",
  "author": "Platform Team",
  "summary": "Full application stack profile: Python app with PostgreSQL and systemd service",
  "license": "Apache-2.0",
  "source": "https://github.com/example-org/puppet-profile_app_stack",
  "dependencies": [
    { "name": "puppetlabs-stdlib", "version_requirement": ">= 9.0.0 < 10.0.0" },
    { "name": "puppetlabs-vcsrepo", "version_requirement": ">= 6.0.0 < 7.0.0" }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "RedHat",
      "operatingsystemrelease": ["8", "9"]
